WECHAT_NEED_OPEN_COMMENT="false"
WECHAT_ONLY_FANS_CAN_COMMENT="false"
WECHAT_REAL_PUBLISH_ENABLED="false"
WECHAT_SUBMIT_FREEPUBLISH="false"

# Draft connector baseline for non-WeChat platforms.
# The connector endpoint can be a local automation service or a platform-specific API proxy.
# Keep real draft targets disabled by default; run `pnpm drafts:enable-local`
# to enable the local outbox connector for Zhihu, Bilibili, and Xiaohongshu.
