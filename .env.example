DATABASE_URL="postgresql://mp_publishing:mp_publishing@localhost:5432/mp_publishing?schema=public"
REDIS_URL="redis://localhost:6380"
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001"
PUBLISH_QUEUE_NAME="mp-publishing-publish-targets"
PUBLISH_WORKER_CONCURRENCY="4"

# WeChat Official Account credential reference used by the demo WeChat account.
# Runtime stores only this reference; secret values are read from environment variables.
WECHAT_OFFICIAL_ACCOUNT_CREDENTIAL_REF="env:WECHAT_OFFICIAL_ACCOUNT"
WECHAT_OFFICIAL_ACCOUNT_APP_ID=""
WECHAT_OFFICIAL_ACCOUNT_APP_SECRET=""
WECHAT_OFFICIAL_ACCOUNT_ACCESS_TOKEN=""
WECHAT_OFFICIAL_ACCOUNT_REFRESH_TOKEN=""
WECHAT_OFFICIAL_ACCOUNT_EXPIRES_AT=""
