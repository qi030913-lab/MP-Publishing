# Optional creator-center automation service for connector upstream forwarding.
# Point DRAFT_CONNECTOR_<PLATFORM>_UPSTREAM_DRAFT_ENDPOINT to
# http://localhost:3030/<platform>/drafts when this service runs with a real handler;
# set DRAFT_CONNECTOR_<PLATFORM>_UPSTREAM_DRAFT_API_KEY to the automation service key.
DRAFT_AUTOMATION_SERVICE_PORT="3030"
DRAFT_AUTOMATION_SERVICE_API_KEY=""
DRAFT_AUTOMATION_SERVICE_HANDLER_MODULE="scripts/handlers/playwright-draft-handler.mjs"
DRAFT_AUTOMATION_REQUIRE_SESSION="false"
DRAFT_AUTOMATION_PLAYWRIGHT_HEADLESS="true"
DRAFT_AUTOMATION_PLAYWRIGHT_TIMEOUT_MS="30000"
DRAFT_AUTOMATION_ZHIHU_CREATOR_BASE_URL=""
DRAFT_AUTOMATION_ZHIHU_CREATOR_DRAFT_URL=""
DRAFT_AUTOMATION_ZHIHU_COOKIES=""
DRAFT_AUTOMATION_ZHIHU_STORAGE_STATE_PATH=""
DRAFT_AUTOMATION_ZHIHU_PLAYWRIGHT_SELECTORS_PATH=""
DRAFT_AUTOMATION_BILIBILI_CREATOR_BASE_URL=""
DRAFT_AUTOMATION_BILIBILI_CREATOR_DRAFT_URL=""
DRAFT_AUTOMATION_BILIBILI_COOKIES=""
DRAFT_AUTOMATION_BILIBILI_STORAGE_STATE_PATH=""
DRAFT_AUTOMATION_BILIBILI_PLAYWRIGHT_SELECTORS_PATH=""
